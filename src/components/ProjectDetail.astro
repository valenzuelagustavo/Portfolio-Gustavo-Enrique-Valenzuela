---
/*
  Página de detalle de un proyecto, como componente reutilizable.
  Lo usan tanto /es/proyectos/[slug] como /en/proyectos/[slug], pasándole el
  idioma. Cada ruta ya le pasa el proyecto correspondiente a SU idioma (viene
  de content/projects/es/ o content/projects/en/), así que acá no hay que
  traducir el contenido: solo la interfaz (volver, etiquetas, botones).
*/
import { render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from './Container.astro';
import Header from './Header.astro';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  project: CollectionEntry<'projects'>;
  lang: Lang;
}

const { project, lang } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(project);
const { title, description, tech, repo, demo, kind } = project.data;

const kindLabel = kind === 'guiado' ? t('project.kind.guiado') : t('project.kind.personal');
const kindClass =
  kind === 'guiado' ? 'border-border text-muted' : 'border-accent/40 text-accent';
---

<BaseLayout lang={lang} title={`${title} — ${'Gustavo Valenzuela'}`} description={description}>
  <Header lang={lang} />

  <Container as="main" class="py-16">
    <a href={`/${lang}/#proyectos`} class="link text-sm">{t('project.back')}</a>

    <span
      class={`mt-6 inline-block rounded-full border px-2 py-0.5 font-mono text-[11px] ${kindClass}`}
    >
      {kindLabel}
    </span>

    <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
    <p class="mt-3 text-lg text-muted">{description}</p>

    <ul class="mt-5 flex flex-wrap gap-2">
      {tech.map((techItem) => <li class="chip">{techItem}</li>)}
    </ul>

    {
      (repo || demo) && (
        <div class="mt-6 flex flex-wrap gap-3">
          {demo && (
            <a href={demo} target="_blank" rel="noopener noreferrer" class="btn-primary">
              {t('project.demo')}
            </a>
          )}
          {repo && (
            <a href={repo} target="_blank" rel="noopener noreferrer" class="btn-ghost">
              {t('project.repo')}
            </a>
          )}
        </div>
      )
    }

    <div class="prose mt-10 border-t border-border pt-8">
      <Content />
    </div>
  </Container>
</BaseLayout>
