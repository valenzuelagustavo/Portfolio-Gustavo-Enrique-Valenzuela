---
/*
  Sección "Sobre mí". Recibe `lang`. Los párrafos vienen del diccionario y
  contienen <strong>, por eso se renderizan con set:html. El estilo de esos
  <strong> se define abajo, en el bloque <style> con scope a este componente.
*/
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="sobre-mi" class="border-t border-border py-20">
  <p class="font-mono text-sm text-accent">{t('about.tag')}</p>
  <h2 class="mt-3 text-3xl font-bold tracking-tight">{t('about.title')}</h2>

  <div class="mt-8 grid gap-8 md:grid-cols-[1.6fr_1fr]">
    <div class="about-prose flex flex-col gap-4 text-pretty text-muted">
      <p set:html={t('about.p1')} />
      <p set:html={t('about.p2')} />
      <p set:html={t('about.p3')} />
    </div>

    <aside class="card flex flex-col gap-5 p-6">
      <div>
        <h3 class="font-mono text-xs uppercase tracking-wider text-accent">
          {t('about.focus.title')}
        </h3>
        <p class="mt-2 text-sm text-muted">{t('about.focus.text')}</p>
      </div>
      <div class="border-t border-border pt-5">
        <h3 class="font-mono text-xs uppercase tracking-wider text-accent">
          {t('about.seeking.title')}
        </h3>
        <p class="mt-2 text-sm text-muted">{t('about.seeking.text')}</p>
      </div>
    </aside>
  </div>
</section>

<style>
  /* Las negritas dentro de los párrafos de "Sobre mí" usan el color de texto
     principal para resaltar sin gritar. */
  .about-prose :global(strong) {
    color: var(--color-fg);
    font-weight: 500;
  }
</style>
