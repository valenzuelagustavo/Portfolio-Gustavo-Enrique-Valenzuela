---
/*
  Sección "Skills". Recibe `lang`. El heading y los títulos de grupo salen del
  diccionario; los items (tecnologías) se muestran tal cual.
*/
import { skillGroups } from '../data/skills';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="skills" class="border-t border-border py-20">
  <p class="font-mono text-sm text-accent">{t('skills.tag')}</p>
  <h2 class="mt-3 text-3xl font-bold tracking-tight">{t('skills.title')}</h2>
  <p class="mt-3 max-w-prose text-muted">{t('skills.intro')}</p>

  <div class="mt-8 grid gap-6 sm:grid-cols-2">
    {
      skillGroups.map((group) => (
        <div class="card p-6">
          <h3 class="font-mono text-xs uppercase tracking-wider text-muted">
            {t(group.titleKey)}
          </h3>
          <ul class="mt-4 flex flex-wrap gap-2">
            {group.items.map((item) => (
              <li class="chip">{item}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
