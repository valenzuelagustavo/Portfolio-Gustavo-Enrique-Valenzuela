---
/*
  Sección "Skills".
  Recorre los grupos de src/data/skills.ts y muestra cada uno con su título y
  sus tecnologías como "chips". Una grilla simple que se adapta de 1 a 2
  columnas según el ancho de pantalla.
*/
import { skillGroups } from '../data/skills';
---

<section id="skills" class="border-t border-border py-20">
  <p class="font-mono text-sm text-accent">// skills</p>
  <h2 class="mt-3 text-3xl font-bold tracking-tight">Tecnologías</h2>
  <p class="mt-3 max-w-prose text-muted">
    Lo que manejo y estoy usando hoy. Prefiero mostrar pocas cosas bien antes
    que inflar la lista.
  </p>

  <div class="mt-8 grid gap-6 sm:grid-cols-2">
    {
      skillGroups.map((group) => (
        <div class="card p-6">
          <h3 class="font-mono text-xs uppercase tracking-wider text-muted">
            {group.title}
          </h3>
          <ul class="mt-4 flex flex-wrap gap-2">
            {group.items.map((item) => (
              <li class="chip">{item}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
