---
/*
  Tarjeta de un proyecto. Recibe la entrada de la colección y el idioma.
  El contenido (título, descripción) está en español; la interfaz (etiqueta de
  tipo, "Ver detalle") se traduce. El link de detalle lleva el prefijo de idioma.

  Nota de accesibilidad: NO envolvemos toda la tarjeta en un <a> para no anidar
  links (el repo/demo quedarían dentro de otro link, lo cual es inválido).
*/
import type { CollectionEntry } from 'astro:content';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  project: CollectionEntry<'projects'>;
  lang: Lang;
}

const { project, lang } = Astro.props;
const t = useTranslations(lang);
const { title, description, tech, repo, demo, kind } = project.data;
const href = `/${lang}/proyectos/${project.id}/`;

const kindLabel = kind === 'guiado' ? t('project.kind.guiado') : t('project.kind.personal');
const kindClass =
  kind === 'guiado' ? 'border-border text-muted' : 'border-accent/40 text-accent';
---

<article class="card flex flex-col gap-3 p-5">
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-lg font-semibold">
      <a href={href} class="transition-colors hover:text-accent">{title}</a>
    </h3>
    <span
      class={`shrink-0 rounded-full border px-2 py-0.5 font-mono text-[11px] ${kindClass}`}
    >
      {kindLabel}
    </span>
  </div>

  <p class="text-sm text-muted">{description}</p>

  <ul class="flex flex-wrap gap-2">
    {tech.map((techItem) => <li class="chip">{techItem}</li>)}
  </ul>

  <div class="mt-auto flex flex-wrap items-center gap-4 pt-2 text-sm">
    <a href={href} class="link font-medium">{t('project.detail')}</a>
    {
      repo && (
        <a
          href={repo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted transition-colors hover:text-fg"
        >
          Repo
        </a>
      )
    }
    {
      demo && (
        <a
          href={demo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted transition-colors hover:text-fg"
        >
          Demo
        </a>
      )
    }
  </div>
</article>
