---
/*
  Sección "Contacto". Recibe `lang`. Los textos de interfaz se traducen; el
  email, el usuario de GitHub y el de LinkedIn no cambian con el idioma.
*/
import { site } from '../data/site';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contacto" class="border-t border-border py-20">
  <p class="font-mono text-sm text-accent">{t('contact.tag')}</p>
  <h2 class="mt-3 text-3xl font-bold tracking-tight">{t('contact.title')}</h2>
  <p class="mt-3 max-w-prose text-muted">{t('contact.intro')}</p>

  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    <!-- Email -->
    <a href={`mailto:${site.email}`} class="card flex items-center gap-4 p-5">
      <span
        class="grid h-10 w-10 shrink-0 place-items-center rounded-lg bg-base text-accent ring-1 ring-border"
        aria-hidden="true"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="m22 7-10 5L2 7"></path>
        </svg>
      </span>
      <span class="min-w-0">
        <span class="block text-sm font-semibold text-fg">Email</span>
        <span class="block truncate text-sm text-muted">{site.email}</span>
      </span>
    </a>

    <!-- GitHub -->
    <a href={site.github} target="_blank" rel="noopener noreferrer" class="card flex items-center gap-4 p-5">
      <span
        class="grid h-10 w-10 shrink-0 place-items-center rounded-lg bg-base text-accent ring-1 ring-border"
        aria-hidden="true"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.58 2 12.26c0 4.5 2.87 8.32 6.84 9.67.5.1.68-.22.68-.49 0-.24-.01-.87-.01-1.71-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.55-1.14-4.55-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05A9.4 9.4 0 0 1 12 6.84c.85 0 1.71.12 2.51.34 1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.04 10.04 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z"></path>
        </svg>
      </span>
      <span class="min-w-0">
        <span class="block text-sm font-semibold text-fg">GitHub</span>
        <span class="block truncate text-sm text-muted">@valenzuelagustavo</span>
      </span>
    </a>

    <!-- LinkedIn (solo si está cargado en site.ts) -->
    {
      site.linkedin && (
        <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="card flex items-center gap-4 p-5">
          <span
            class="grid h-10 w-10 shrink-0 place-items-center rounded-lg bg-base text-accent ring-1 ring-border"
            aria-hidden="true"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M4.98 3.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5ZM3 9h4v12H3V9Zm6 0h3.8v1.64h.05c.53-1 1.83-2.05 3.77-2.05C20.6 8.59 22 10.27 22 13.6V21h-4v-6.56c0-1.56-.03-3.57-2.18-3.57-2.18 0-2.51 1.7-2.51 3.46V21H9V9Z" />
            </svg>
          </span>
          <span class="min-w-0">
            <span class="block text-sm font-semibold text-fg">LinkedIn</span>
            <span class="block truncate text-sm text-muted">Ver perfil</span>
          </span>
        </a>
      )
    }
  </div>
</section>
