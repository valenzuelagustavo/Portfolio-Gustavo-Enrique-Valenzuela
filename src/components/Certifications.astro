---
/*
  Sección "Cursos y certificaciones". Recibe `lang`. Los datos salen de
  src/data/certifications.ts: una lista plana de cursos (title, provider,
  date). Acá los agrupamos por `provider` y ordenamos los grupos por
  actividad más reciente, así sumar un curso nuevo —de un proveedor que ya
  existe o de uno nuevo— no requiere tocar este componente, solo el array
  de datos.
*/
import { certifications } from '../data/certifications';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const dateFormatter = new Intl.DateTimeFormat(lang === 'es' ? 'es-AR' : 'en-US', {
  year: 'numeric',
  month: 'long',
});

// Se ancla a T00:00:00Z para que la fecha no cambie de mes según el huso
// horario de quien esté viendo la página.
function formatDate(iso: string) {
  return dateFormatter.format(new Date(`${iso}T00:00:00Z`));
}

const grouped = new Map<string, typeof certifications>();
for (const cert of certifications) {
  const list = grouped.get(cert.provider) ?? [];
  list.push(cert);
  grouped.set(cert.provider, list);
}

const groups = [...grouped.entries()]
  .map(([provider, items]) => ({
    provider,
    items: [...items].sort((a, b) => b.date.localeCompare(a.date)),
  }))
  .sort((a, b) => b.items[0].date.localeCompare(a.items[0].date));
---

<section id="certificaciones" class="border-t border-border py-20">
  <p class="font-mono text-sm text-accent">{t('certifications.tag')}</p>
  <h2 class="mt-3 text-3xl font-bold tracking-tight">{t('certifications.title')}</h2>
  <p class="mt-3 max-w-prose text-muted">{t('certifications.intro')}</p>

  <div class="mt-8 grid gap-6 sm:grid-cols-2">
    {
      groups.map((group) => (
        <div class="card p-6">
          <h3 class="font-mono text-xs uppercase tracking-wider text-muted">{group.provider}</h3>
          <ul class="mt-4 flex flex-col gap-3">
            {group.items.map((cert) => (
              <li class="flex flex-col gap-0.5 text-sm">
                <span class="text-fg">{cert.title}</span>
                <span class="font-mono text-xs text-muted">{formatDate(cert.date)}</span>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
