---
/*
  Header sticky y responsive, ahora bilingüe.
  - Recibe `lang` (idioma actual).
  - Los links de navegación se arman con el prefijo de idioma: /es/#... o /en/#...
  - El selector de idioma (EN/ES) lleva a la MISMA página en el otro idioma:
    toma la ruta actual, le saca el prefijo y le pone el del otro idioma.
*/
import { navItems, useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Idioma "del otro botón" y la ruta equivalente en ese idioma.
const other: Lang = lang === 'es' ? 'en' : 'es';
const rest = Astro.url.pathname.replace(/^\/(es|en)/, '') || '/';
const switchHref = `/${other}${rest}`;
---

<header class="sticky top-0 z-50 border-b border-border/60 bg-base/80 backdrop-blur-md">
  <nav
    class="mx-auto flex h-14 max-w-3xl items-center justify-between px-6"
    aria-label={t('nav.aria')}
  >
    <a
      href={`/${lang}/`}
      class="font-mono text-sm font-semibold tracking-tight text-fg transition-colors hover:text-accent"
    >
      Gustavo<span class="text-accent">.dev</span>
    </a>

    <div class="flex items-center gap-5">
      <!-- Navegación (desktop) -->
      <ul class="hidden items-center gap-6 sm:flex">
        {
          navItems.map((item) => (
            <li>
              <a
                href={`/${lang}/#${item.id}`}
                class="text-sm text-muted transition-colors hover:text-fg"
              >
                {t(item.key)}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Selector de idioma -->
      <a
        href={switchHref}
        class="rounded-md border border-border px-2 py-1 font-mono text-xs text-muted transition-colors hover:border-accent hover:text-accent"
        aria-label={t('header.switchLang')}
        title={t('header.switchLang')}
      >
        {other.toUpperCase()}
      </a>

      <!-- Botón menú (mobile) -->
      <button
        id="menu-toggle"
        type="button"
        class="-mr-2 inline-flex items-center justify-center rounded-md p-2 text-fg transition-colors hover:text-accent sm:hidden"
        aria-label={t('header.openMenu')}
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-open-label={t('header.openMenu')}
        data-close-label={t('header.closeMenu')}
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Panel de navegación (mobile) -->
  <div
    id="mobile-menu"
    hidden
    class="border-t border-border/60 bg-base/95 backdrop-blur-md sm:hidden"
  >
    <ul class="mx-auto flex max-w-3xl flex-col px-6 py-2">
      {
        navItems.map((item) => (
          <li>
            <a
              href={`/${lang}/#${item.id}`}
              data-menu-link
              class="block py-2.5 text-muted transition-colors hover:text-fg"
            >
              {t(item.key)}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  // Toggle del menú mobile + accesibilidad (aria-expanded) + cierre al navegar.
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const openLabel = toggle?.dataset.openLabel ?? 'Abrir menú';
  const closeLabel = toggle?.dataset.closeLabel ?? 'Cerrar menú';

  function closeMenu() {
    menu?.setAttribute('hidden', '');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', openLabel);
  }

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = !menu.hasAttribute('hidden');
      if (isOpen) {
        closeMenu();
      } else {
        menu.removeAttribute('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        toggle.setAttribute('aria-label', closeLabel);
      }
    });

    menu.querySelectorAll('[data-menu-link]').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  }
</script>
