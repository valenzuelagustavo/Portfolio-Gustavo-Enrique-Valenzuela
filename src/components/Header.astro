---
/*
  Header sticky (fijo arriba) y responsive.
  - En desktop: nombre a la izquierda, navegación a la derecha.
  - En mobile: botón hamburguesa que despliega un panel con los links.
  El menú mobile usa un poquito de JS (al final) con atributos ARIA para que
  sea accesible: el lector de pantalla sabe si está abierto o cerrado.
  Los links de navegación salen de src/data/site.ts (un solo lugar para editarlos).
*/
import { site, nav } from '../data/site';
---

<header
  class="sticky top-0 z-50 border-b border-border/60 bg-base/80 backdrop-blur-md"
>
  <nav
    class="mx-auto flex h-14 max-w-3xl items-center justify-between px-6"
    aria-label="Navegación principal"
  >
    <!-- Logo / nombre -->
    <a
      href="/#inicio"
      class="font-mono text-sm font-semibold tracking-tight text-fg transition-colors hover:text-accent"
    >
      {site.name.split(' ')[0]}<span class="text-accent">.dev</span>
    </a>

    <!-- Navegación (desktop) -->
    <ul class="hidden items-center gap-6 sm:flex">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-sm text-muted transition-colors hover:text-fg"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Botón menú (mobile) -->
    <button
      id="menu-toggle"
      type="button"
      class="-mr-2 inline-flex items-center justify-center rounded-md p-2 text-fg transition-colors hover:text-accent sm:hidden"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </nav>

  <!-- Panel de navegación (mobile) -->
  <div
    id="mobile-menu"
    hidden
    class="border-t border-border/60 bg-base/95 backdrop-blur-md sm:hidden"
  >
    <ul class="mx-auto flex max-w-3xl flex-col px-6 py-2">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              data-menu-link
              class="block py-2.5 text-muted transition-colors hover:text-fg"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  // Toggle del menú mobile + accesibilidad (aria-expanded) + cierre al navegar.
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  function closeMenu() {
    menu?.setAttribute('hidden', '');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Abrir menú');
  }

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = !menu.hasAttribute('hidden');
      if (isOpen) {
        closeMenu();
      } else {
        menu.removeAttribute('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        toggle.setAttribute('aria-label', 'Cerrar menú');
      }
    });

    // Al tocar un link del menú, lo cerramos.
    menu.querySelectorAll('[data-menu-link]').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });
  }
</script>
