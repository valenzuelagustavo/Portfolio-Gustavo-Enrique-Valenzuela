---
/*
  Sección "Proyectos". Recibe `lang` y se lo pasa a cada tarjeta (para que los
  links de detalle y las etiquetas estén en el idioma correcto). El contenido de
  cada proyecto también está en el idioma correcto: lo filtramos más abajo por
  el prefijo del id ("es/" o "en/"), así que cada tarjeta ya recibe la versión
  del proyecto que corresponde.
*/
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// El contenido vive en subcarpetas por idioma (projects/es/, projects/en/).
// El id de cada entrada arranca con el idioma (ej: "es/dosto"), así que
// filtramos por el idioma actual y ordenamos por "order".
const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .filter((p) => p.id.startsWith(`${lang}/`))
  .sort((a, b) => a.data.order - b.data.order);
---

<section id="proyectos" class="border-t border-border py-20">
  <p class="font-mono text-sm text-accent">{t('projects.tag')}</p>
  <h2 class="mt-3 text-3xl font-bold tracking-tight">{t('projects.title')}</h2>
  <p class="mt-3 max-w-prose text-muted">{t('projects.intro')}</p>

  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    {projects.map((project) => <ProjectCard project={project} lang={lang} />)}
  </div>
</section>
