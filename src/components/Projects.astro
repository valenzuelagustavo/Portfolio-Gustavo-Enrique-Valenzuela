---
/*
  Sección "Proyectos". Lee la content collection, descarta borradores y ordena
  por el campo "order", y muestra una tarjeta por proyecto en una grilla que
  pasa de 1 a 2 columnas según el ancho.
*/
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section id="proyectos" class="border-t border-border py-20">
  <p class="font-mono text-sm text-accent">// proyectos</p>
  <h2 class="mt-3 text-3xl font-bold tracking-tight">Proyectos</h2>
  <p class="mt-3 max-w-prose text-muted">
    Algunas cosas que construí mientras aprendo. Cada una tiene su página con
    más detalle de qué hice y qué aprendí.
  </p>

  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    {projects.map((project) => <ProjectCard project={project} />)}
  </div>
</section>
