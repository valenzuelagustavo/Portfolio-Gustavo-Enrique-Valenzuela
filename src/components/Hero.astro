---
/*
  Hero: la primera sección. Recibe `lang` y toma todos sus textos del
  diccionario de traducciones. El nombre no cambia con el idioma, pero el CV
  sí: hay una versión en español y otra en inglés.
*/
import { site } from '../data/site';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  id="inicio"
  class="relative flex min-h-[calc(100svh-3.5rem)] flex-col justify-center py-20"
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-20 left-1/2 -z-10 h-64 w-[36rem] max-w-full -translate-x-1/2 rounded-full bg-accent-strong/15 blur-3xl"
  >
  </div>

  <div class="flex flex-col gap-5">
    <p class="font-mono text-sm text-accent">{t('hero.tag')}</p>

    <h1 class="text-4xl font-bold tracking-tight sm:text-6xl">
      {site.name}
    </h1>

    <p class="max-w-prose text-pretty text-lg text-muted">
      {t('hero.lead')}
    </p>

    <div class="mt-2 flex flex-wrap gap-3">
      <a href="#proyectos" class="btn-primary">{t('hero.cta.projects')}</a>
      <a href={site.cvPath(lang)} class="btn-ghost" download>{t('hero.cta.cv')}</a>
    </div>
  </div>
</section>
