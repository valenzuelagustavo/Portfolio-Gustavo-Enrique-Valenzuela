---
/*
  Layout base: el "molde" HTML que comparten todas las páginas.
  Ahora recibe `lang` para poner el idioma correcto en <html lang> y en las
  etiquetas de SEO. Los hreflang le dicen a Google que existe la misma página en
  el otro idioma (importante para sitios bilingües).
*/
import '../styles/global.css';
import { site } from '../data/site';
import type { Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
}

const {
  lang = 'es',
  title = `${site.name} — Portfolio`,
  description = `Portfolio de ${site.name}, ${site.role}.`,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Ruta sin el prefijo de idioma, para armar los hreflang del otro idioma.
const rest = Astro.url.pathname.replace(/^\/(es|en)/, '') || '/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Versiones por idioma de esta misma página (SEO) -->
    <link rel="alternate" hreflang="es" href={new URL(`/es${rest}`, Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL(`/en${rest}`, Astro.site)} />
    <link rel="alternate" hreflang="x-default" href={new URL(`/es${rest}`, Astro.site)} />

    <!-- Tipografías: Inter (cuerpo) + JetBrains Mono (código/detalles). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={lang === 'es' ? 'es_AR' : 'en_US'} />
  </head>
  <body class="min-h-screen bg-base font-sans text-fg antialiased">
    <slot />

    <script>
      // Links de email a prueba de scraping (ver src/lib/obfuscate-email.ts).
      //
      // Clave: el email NUNCA se escribe en el DOM — ni en un href, ni como
      // texto visible, ni al cargar ni después. Las extensiones que cosechan
      // emails leen el DOM ya renderizado (por eso la versión anterior, que
      // armaba el mailto: al cargar la página, seguía siendo capturable).
      // Acá el email solo se decodifica en memoria durante el click de una
      // persona real, y se navega directo al mailto: sin dejar rastro en el
      // documento.
      import { decodeEmail } from '../lib/obfuscate-email';

      document.querySelectorAll<HTMLAnchorElement>('[data-email]').forEach((el) => {
        el.addEventListener('click', (ev) => {
          ev.preventDefault();
          const encoded = el.dataset.email;
          if (!encoded) return;
          window.location.href = `mailto:${decodeEmail(encoded)}`;
        });
      });
    </script>
  </body>
</html>
