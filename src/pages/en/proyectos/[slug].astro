---
/*
  Detalle de proyecto en inglés: /en/proyectos/<slug>
  Igual que la versión española pero tomando los proyectos de projects/en/.
*/
import { getCollection } from 'astro:content';
import ProjectDetail from '../../../components/ProjectDetail.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects
    .filter((project) => project.id.startsWith('en/'))
    .map((project) => ({
      params: { slug: project.id.split('/').pop() },
      props: { project },
    }));
}

const { project } = Astro.props;
---

<ProjectDetail project={project} lang="en" />
