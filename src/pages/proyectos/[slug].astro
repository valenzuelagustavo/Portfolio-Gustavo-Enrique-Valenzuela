---
/*
  Ruta vieja (sin idioma) /proyectos/<slug>: ahora redirige a la versión en
  español /es/proyectos/<slug>. Mantiene vivos los links antiguos por si alguien
  los tenía guardados.
*/
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
  }));
}

return Astro.redirect(`/es/proyectos/${Astro.params.slug}/`);
---
